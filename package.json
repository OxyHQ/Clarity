{
  "name": "clarity-monorepo",
  "version": "1.0.0",
  "description": "Clarity - AI-powered search engine with cited sources",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/app"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:app": "bun run --filter @clarity/app dev -- --clear --tunnel",
    "dev:api": "bun run --filter @clarity/api dev",
    "build": "bun run --filter '*' build",
    "build:app": "bun run --filter @clarity/app build",
    "build:api": "bun run --filter @clarity/api build",
    "start:app": "bun run --filter @clarity/app start",
    "start:api": "bun run --filter @clarity/api start",
    "lint": "bun run --filter '*' lint",
    "android": "bun run --filter @clarity/app android",
    "ios": "bun run --filter @clarity/app ios",
    "web": "bun run --filter @clarity/app web"
  },
  "keywords": [
    "monorepo",
    "ai",
    "search",
    "expo",
    "api",
    "clarity"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "sst": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.8.3",
    "react-native-reanimated": "4.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo-secure-store": "56.0.4",
    "expo-file-system": "56.0.8",
    "react-native-screens": "4.25.2",
    "react-native-gesture-handler": "2.31.1",
    "react-native-keyboard-controller": "1.20.7",
    "expo": "56.0.11",
    "expo-blur": "56.0.3",
    "expo-constants": "56.0.18",
    "expo-font": "56.0.6",
    "expo-image": "56.0.11",
    "@react-native-menu/menu": "2.0.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/metro-babel-transformer": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@oxyhq/core": "3.6.0",
    "lightningcss": "1.30.1",
    "lightningcss-linux-x64-gnu": "1.30.1",
    "lightningcss-linux-x64-musl": "1.30.1"
  },
  "dependencies": {
    "@oxyhq/auth": "^4.1.1",
    "@oxyhq/core": "3.6.0"
  }
}
