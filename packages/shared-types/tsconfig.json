{
  // ---------------------------------------------------------------------------
  // @clarity/shared-types
  //
  // Type definitions shared by BOTH the backend (Node/Bun, ESM) and the
  // frontend (Metro/Expo bundler). It is the single emitting leaf both runtimes
  // consume at the same time, so its output must be safe for each.
  //
  // It emits ESM to `dist/` (with .d.ts declarations) because the backend is an
  // ESM package ("type": "module") that imports the compiled output, and Metro
  // happily consumes the same ESM + declarations. A single ESM build serves both.
  //
  // MODEL ABSTRACTION RULE: types exported here are user/developer-facing.
  // They must NEVER expose internal provider names, provider model IDs, or
  // provider routing/mapping details. Only Clarity-branded model identities.
  // ---------------------------------------------------------------------------
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
