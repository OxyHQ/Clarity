# ================================
# EXPO APP CONFIGURATION
# ================================
# API server URL
EXPO_PUBLIC_API_URL=http://localhost:3001

# Telegram bot username (for login deep link)
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=alia_onlbot

# Sentry DSN for error tracking (optional)
# EXPO_PUBLIC_SENTRY_DSN=

# ================================
# PERFORMANCE OPTIMIZATIONS
# ================================
# Tree shaking removes unused code from production bundles (Expo SDK 52+)
EXPO_UNSTABLE_TREE_SHAKING=1
EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1

# ================================
# PROVIDERS (DEV)
# ================================
# When set, backend can route to DigitalOcean inference
# DIGITALOCEAN_API_KEY=your-digitalocean-inference-key

# ================================
# INTERNAL (used by build scripts, not exposed to client)
# ================================
# API base URL for server-side operations
API_BASE_URL=http://localhost:3001

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your values
# - EXPO_PUBLIC_ prefix exposes vars to the client bundle
# - Never put secrets in EXPO_PUBLIC_ variables
# - For production values, see apps/app/.env.production
