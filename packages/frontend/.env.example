# ================================
# EXPO APP CONFIGURATION
# ================================
# API server URL
EXPO_PUBLIC_API_URL=http://localhost:3001

# Oxy SSO client id (registered RP client for cross-app device sign-in / SSO).
# Optional; enables the SDK SSO/cold-boot flow when set.
EXPO_PUBLIC_OXY_CLIENT_ID=

# Telegram bot username (for login deep link)
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=alia_onlbot

# Sentry DSN for error tracking (optional)
# EXPO_PUBLIC_SENTRY_DSN=

# ================================
# PERFORMANCE OPTIMIZATIONS
# ================================
# Tree shaking removes unused code from production bundles (Expo SDK 52+)
EXPO_UNSTABLE_TREE_SHAKING=1
EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your values
# - EXPO_PUBLIC_ prefix exposes vars to the client bundle
# - Never put secrets in EXPO_PUBLIC_ variables
# - For production values, see packages/frontend/.env.production
