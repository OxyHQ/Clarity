# ================================
# DATABASE CONFIGURATION
# ================================
# MongoDB connection string
# Local: mongodb://localhost:27017/alia
# Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/alia
MONGODB_URI=mongodb://localhost:27017/alia

# ================================
# API SERVER CONFIGURATION
# ================================
# Port where the API server will run
PORT=3001

# URL of the web application (for CORS)
WEB_URL=http://localhost:3000

# URL of the mobile app (for authentication redirects)
# If not set, will use WEB_URL
APP_URL=http://localhost:3000

# URL of the API server itself (for generating auth links)
API_BASE_URL=http://localhost:3001

# ================================
# AUTHENTICATION
# ================================
# Secret key for JWT token generation
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ================================
# INTERNAL PROVIDERS MODULE
# ================================
# Service secret for admin panel authentication (HMAC)
# Generate with: openssl rand -hex 32
SERVICE_SECRET=your-service-secret-min-32-chars-change-this

# ================================
# AWS S3 CONFIGURATION
# ================================
# Required for avatar uploads and file storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# ================================
# AI PROVIDER API KEYS
# ================================
# Keys can be provided via environment variables (for local dev) or stored in MongoDB (for production).
# The key-manager checks MongoDB first, then falls back to env vars.
#
# Format: PROVIDER_KEYS=key1,key2,key3 (comma-separated for multiple keys)
# Alternative: PROVIDER_API_KEY=single-key

# DigitalOcean Inference (PRIMARY provider — used for all tiers)
# Get a key at https://cloud.digitalocean.com/gen-ai/platform
# DIGITALOCEAN_KEYS=your-digitalocean-inference-key

# Google AI (Gemini) — fallback provider
# GOOGLE_KEYS=your-google-api-key

# OpenAI (GPT-4) — fallback provider
# OPENAI_KEYS=your-openai-api-key

# Anthropic (Claude) — fallback provider
# ANTHROPIC_KEYS=your-anthropic-api-key

# Groq (Fast inference) — fallback provider
# GROQ_KEYS=your-groq-api-key

# Together AI — fallback provider
# TOGETHER_KEYS=your-together-api-key

# Cerebras (Fast inference) — fallback provider
# CEREBRAS_KEYS=your-cerebras-api-key

# ================================
# INTEGRATIONS SERVICE
# ================================
# URL of the unified integrations service (proxies gateway requests)
# INTEGRATIONS_SERVICE_URL=http://localhost:3005

# Shared secret for integrations service <-> API internal auth
# Generate with: openssl rand -hex 32
# INTEGRATIONS_SECRET=your-integrations-secret

# ================================
# CHANNEL BOT SECRETS
# ================================
# Per-channel secrets for bot <-> API authentication (x-channel-bot-secret header)
# Each must match the corresponding secret in the integrations service
# Generate with: openssl rand -hex 32

# Telegram Bot
TELEGRAM_BOT_USERNAME=alia_onlbot
# TELEGRAM_BOT_SECRET=your-telegram-bot-secret

# Discord Bot
# DISCORD_BOT_SECRET=your-discord-bot-secret

# Slack Bot (future)
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret
# SLACK_BOT_SECRET=your-slack-bot-secret

# ================================
# EMAIL (Organization Invitations)
# ================================
# Resend API key for sending invitation emails
# Get one at https://resend.com
# If not set, invitation emails are logged to console (dev mode)
# RESEND_API_KEY=re_your_resend_api_key
# Optional: customize sender address (default: Alia <noreply@alia.space>)
# RESEND_FROM_EMAIL=Alia <noreply@alia.space>

# ================================
# REDIS (Task Queue for Async Agent Sessions)
# ================================
# Required for BullMQ async task queue. If not set, agent sessions run directly (fire-and-forget).
# Local: redis://localhost:6379
# Managed: rediss://user:password@host:port
# REDIS_URL=redis://localhost:6379

# ================================
# DOCKER HOST (Container System for Agents)
# ================================
# URL of the Docker host service for agent container management
# DOCKER_HOST_URL=http://<droplet-ip>:9090
# Shared secret for API <-> Docker host authentication
# Generate with: openssl rand -hex 32
# DOCKER_HOST_SECRET=your-docker-host-secret

# ================================
# NOTES
# ================================
# - Copy this file to .env and fill in your actual values
# - Never commit .env to version control
# - Rotate JWT_SECRET regularly in production
# - Bot tokens and platform credentials go in the integrations service .env,
#   only the per-channel bot secrets are needed here for auth validation
